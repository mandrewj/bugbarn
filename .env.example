# ── Bug Barn Portal — environment variables ────────────────────────────────
# Copy to .env.local for local dev. Set the same values in Vercel → Project →
# Settings → Environment Variables for production.

# Shared login code that lab staff type on the /login screen (required).
BARN_ACCESS_CODE="change-me-to-a-long-passphrase"

# Secret used to sign the session cookie. Generate with: openssl rand -hex 32
# (optional locally — falls back to BARN_ACCESS_CODE if unset).
AUTH_SECRET=""

# ── Storage (production) ───────────────────────────────────────────────────
# Added automatically when you connect Vercel Blob to the project
# (Vercel → Storage → Blob). Holds bugbarn.json + specimen photos.
# Leave empty for local dev — data is written to ./data/bugbarn.json instead.
BLOB_READ_WRITE_TOKEN=""

# ── GitHub backup (optional, used by the every-2-days cron) ─────────────────
# A fine-grained PAT with Contents: Read & Write on the backup repo only.
GITHUB_TOKEN=""
GITHUB_OWNER=""
GITHUB_REPO="bugbarn-backup"
GITHUB_BRANCH="main"

# Set by Vercel for cron auth. Generate with: openssl rand -hex 32
CRON_SECRET=""
